          :plan {:variant "max"}}}

 :servers
 {:slack {:env {"SLACK_DEFAULT_HOST" "your-workspace.slack.com"}}
  :splunk {:env {"SPLUNK_HOST" "your-instance.splunkcloud.com"}}}

 ;; Extra content appended to AGENTS.md (optional)
